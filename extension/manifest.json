{
  "manifest_version": 3,
  "name": "Multiline Motopeças — Importar ML",
  "description": "Importa produtos do Mercado Livre para o catálogo Multiline Motopeças (pendente de revisão).",
  "version": "1.0.1",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Importar produto do Mercado Livre",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://*.mercadolivre.com.br/*",
    "*://*.mercadolibre.com/*",
    "*://meli.la/*",
    "*://me2.do/*",
    "https://multilinemotopecas.com.br/*",
    "https://multilinemotopecas.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.mercadolivre.com.br/*",
        "*://*.mercadolibre.com/*"
      ],
      "js": ["scraper.js"],
      "run_at": "document_idle"
    }
  ]
}
