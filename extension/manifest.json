{
  "manifest_version": 3,
  "name": "Multiline Motopeças — Importar ML",
  "description": "Importa produtos do Mercado Livre para o catálogo Multiline Motopeças (pendente de revisão).",
  "version": "1.1.2",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Importar produto do Mercado Livre",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "storage", "cookies", "tabs"],
  "host_permissions": [
    "*://*.mercadolivre.com.br/*",
    "*://*.mercadolibre.com/*",
    "*://meli.la/*",
    "*://me2.do/*",
    "https://multilinemotopecas.com.br/*",
    "https://www.multilinemotopecas.com.br/*",
    "https://*.multilinemotopecas.com.br/*",
    "https://multilinemotopecas.vercel.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://multilinemotopecas.com.br/*",
      "https://www.multilinemotopecas.com.br/*",
      "https://*.multilinemotopecas.com.br/*",
      "https://multilinemotopecas.vercel.app/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.mercadolivre.com.br/*",
        "*://*.mercadolibre.com/*"
      ],
      "js": ["scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://multilinemotopecas.com.br/*",
        "https://www.multilinemotopecas.com.br/*",
        "https://*.multilinemotopecas.com.br/*",
        "https://multilinemotopecas.vercel.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["admin-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
