generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum product_status {
  active
  inactive
  draft
  out_of_stock
}

enum listing_status {
  active
  paused
  closed
  not_listed
}

enum price_sync_status {
  success
  failed
  skipped
  low_confidence
  no_url
  blocked
  unavailable
  inactive
}

enum analytics_event_type {
  purchase_click
  product_view
  search
  share
  whatsapp_click
}

model admin_profiles {
  id         String   @id @db.Uuid
  email      String
  full_name  String?
  role       String   @default("admin")
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("admin_profiles")
}

model analytics_events {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type analytics_event_type
  product_id String?              @db.Uuid
  metadata   Json                 @default("{}")
  created_at DateTime             @default(now()) @db.Timestamptz(6)
  products   products?            @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([event_type], map: "idx_analytics_events_type")
  @@map("analytics_events")
}

model brands {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String     @unique
  description String?
  logo_url    String?
  is_active   Boolean    @default(true)
  sort_order  Int        @default(0)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)
  products    products[]

  @@index([slug], map: "idx_brands_slug")
  @@map("brands")
}

model categories {
  id                      String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String     @unique
  description             String?
  image_url               String?
  parent_id               String?    @db.Uuid
  is_active               Boolean    @default(true)
  sort_order              Int        @default(0)
  created_at              DateTime   @default(now()) @db.Timestamptz(6)
  updated_at              DateTime   @default(now()) @db.Timestamptz(6)
  parent                  categories?  @relation("CategoryHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children                categories[] @relation("CategoryHierarchy")
  products_category       products[]   @relation("ProductCategory")
  products_subcategory    products[]   @relation("ProductSubcategory")

  @@index([slug], map: "idx_categories_slug")
  @@map("categories")
}

model faqs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question   String
  answer     String
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("faqs")
}

model motorcycle_model_catalog {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  motorcycle_brand    String
  model               String
  default_displacement String?
  slug                String                @unique
  is_active           Boolean               @default(true)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  motorcycle_versions motorcycle_versions[]

  @@unique([motorcycle_brand, model])
  @@index([motorcycle_brand], map: "idx_motorcycle_catalog_brand")
  @@index([slug], map: "idx_motorcycle_catalog_slug")
  @@map("motorcycle_model_catalog")
}

model motorcycle_models {
  id                              String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  motorcycle_brand                String
  model                           String
  displacement                    String?
  year_start                      Int?
  year_end                        Int?
  slug                            String                            @unique
  is_active                       Boolean                           @default(true)
  created_at                      DateTime                          @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime                          @default(now()) @db.Timestamptz(6)
  product_motorcycle_compatibility product_motorcycle_compatibility[]
  motorcycle_versions             motorcycle_versions[]

  @@index([slug], map: "idx_motorcycle_models_slug")
  @@map("motorcycle_models")
}

model motorcycle_versions {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  catalog_id          String                  @db.Uuid
  version_name        String?
  displacement        String?
  year_start          Int?
  year_end            Int?
  slug                String                  @unique
  motorcycle_model_id String?                 @db.Uuid
  is_active           Boolean                 @default(true)
  created_at          DateTime                @default(now()) @db.Timestamptz(6)
  updated_at          DateTime                @default(now()) @db.Timestamptz(6)
  motorcycle_model_catalog motorcycle_model_catalog @relation(fields: [catalog_id], references: [id], onDelete: Cascade)
  motorcycle_models   motorcycle_models?      @relation(fields: [motorcycle_model_id], references: [id], onDelete: SetNull)

  @@index([catalog_id], map: "idx_motorcycle_versions_catalog")
  @@index([slug], map: "idx_motorcycle_versions_slug")
  @@index([motorcycle_model_id], map: "idx_motorcycle_versions_model_id")
  @@map("motorcycle_versions")
}

model product_images {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String   @db.Uuid
  url        String
  alt_text   String?
  sort_order Int      @default(0)
  is_primary Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model product_motorcycle_compatibility {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id          String            @db.Uuid
  motorcycle_model_id String            @db.Uuid
  year                Int?
  year_end            Int?
  products            products          @relation(fields: [product_id], references: [id], onDelete: Cascade)
  motorcycle_models   motorcycle_models @relation(fields: [motorcycle_model_id], references: [id], onDelete: Cascade)

  @@unique([product_id, motorcycle_model_id], map: "idx_product_moto_compat_model_unique")
  @@map("product_motorcycle_compatibility")
}

model product_reviews {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id  String   @db.Uuid
  author_name String
  rating      Int
  comment     String?
  is_approved Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  products    products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_reviews")
}

model price_sync_logs {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id            String             @db.Uuid
  old_price             Decimal?           @db.Decimal(10, 2)
  new_price             Decimal?           @db.Decimal(10, 2)
  old_promotional_price Decimal?           @db.Decimal(10, 2)
  new_promotional_price Decimal?           @db.Decimal(10, 2)
  status                price_sync_status
  error                 String?
  source_url            String?
  confidence_score      Decimal?           @db.Decimal(5, 4)
  evidence              Json               @default("{}")
  trigger_source        String             @default("manual")
  created_at            DateTime           @default(now()) @db.Timestamptz(6)
  products              products           @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id, created_at(sort: Desc)], map: "idx_price_sync_logs_product_id")
  @@map("price_sync_logs")
}

model price_sync_daily_runs {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_date        DateTime  @unique @db.Date
  started_at      DateTime  @default(now()) @db.Timestamptz(6)
  completed_at    DateTime? @db.Timestamptz(6)
  status          String    @default("running")
  total_products  Int       @default(0)
  processed       Int       @default(0)
  succeeded       Int       @default(0)
  failed          Int       @default(0)
  skipped         Int       @default(0)

  @@map("price_sync_daily_runs")
}

model products {
  id                       String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String
  slug                     String               @unique
  sku                      String
  internal_code            String?
  brand_id                 String?              @db.Uuid
  category_id              String?              @db.Uuid
  subcategory_id           String?              @db.Uuid
  price                    Decimal              @default(0) @db.Decimal(10, 2)
  promotional_price        Decimal?             @db.Decimal(10, 2)
  stock                    Int                  @default(0)
  weight                   Decimal?             @db.Decimal(8, 3)
  dimensions               String?
  short_description        String?
  full_description         String?
  technical_specs          Json                 @default("[]")
  applications             String?
  compatibilities          String?
  product_references       String?
  tags                     String[]             @default([])
  seo_keywords             String[]             @default([])
  mercado_livre_url        String?
  mercado_livre_id         String?
  ml_source_url            String?
  last_price_sync_at       DateTime?            @db.Timestamptz(6)
  last_price_sync_status   price_sync_status?
  last_price_sync_error    String?
  last_synced_price        Decimal?             @db.Decimal(10, 2)
  price_sync_enabled       Boolean              @default(true)
  listing_status           listing_status       @default(not_listed)
  status                   product_status       @default(draft)
  is_featured              Boolean              @default(false)
  is_bestseller            Boolean              @default(false)
  is_new                   Boolean              @default(false)
  is_promotion             Boolean              @default(false)
  is_launch                Boolean              @default(false)
  is_recommended           Boolean              @default(false)
  view_count               Int                  @default(0)
  purchase_click_count     Int                  @default(0)
  search_vector            Unsupported("tsvector")?
  ml_verification_pending  Boolean              @default(false)
  ml_verification_message  String?
  ml_verified_at           DateTime?            @db.Timestamptz(6)
  created_at               DateTime             @default(now()) @db.Timestamptz(6)
  updated_at               DateTime             @default(now()) @db.Timestamptz(6)
  analytics_events         analytics_events[]
  brands                   brands?              @relation(fields: [brand_id], references: [id], onDelete: SetNull)
  categories               categories?          @relation("ProductCategory", fields: [category_id], references: [id], onDelete: SetNull)
  subcategory              categories?          @relation("ProductSubcategory", fields: [subcategory_id], references: [id], onDelete: SetNull)
  product_images           product_images[]
  product_motorcycle_compatibility product_motorcycle_compatibility[]
  product_reviews          product_reviews[]
  price_sync_logs          price_sync_logs[]

  @@index([slug], map: "idx_products_slug")
  @@index([sku], map: "idx_products_sku")
  @@index([brand_id], map: "idx_products_brand")
  @@index([category_id], map: "idx_products_category")
  @@index([status], map: "idx_products_status")
  @@index([ml_verification_pending], map: "idx_products_ml_verification_pending")
  @@map("products")
}

model search_logs {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  query          String
  results_count  Int      @default(0)
  user_agent     String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([query], map: "idx_search_logs_query")
  @@map("search_logs")
}
